# La portada la sirve index.php (arma la vista previa por evento para WhatsApp)
DirectoryIndex index.php index.html

# Evitar que el HTML se cachee (para que las invitaciones actualizadas salgan siempre bien)
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
# LiteSpeed: no cachear los .html de esta carpeta
<IfModule Litespeed>
  RewriteEngine On
  RewriteRule .*\.html$ - [E=Cache-Control:no-cache]
</IfModule>
